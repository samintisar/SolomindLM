# E2E Test Environment Variables
# Copy this file to .env.e2e and fill in your test credentials

# Test account credentials (create a test account in your app)
E2E_TEST_EMAIL=your-test-email@example.com
E2E_TEST_PASSWORD=your-test-password

# Enable AI features in E2E tests (set to 1 to enable)
E2E_AI_ENABLED=0
