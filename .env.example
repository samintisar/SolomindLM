# ============================================
# SolomindLM Environment Variables
# ============================================
# Dev Convex + local backend: copy to `.env.local`
# Prod Convex: copy to `.env` (or pull with convex:env:pull:prod)
#
#   bun run convex:env:pull:dev   # Convex dev  → .env.local
#   bun run convex:env:pull:prod  # Convex prod → .env
#   bun run convex:env:push     # .env.local  → Convex dev
#   bun run convex:env:push:prod
#
# Push skips CONVEX_DEPLOYMENT, CONVEX_URL, RAG_EVAL_CONVEX_URL, and VITE_*.

# ============================================
# CONVEX (local CLI — not pushed)
# ============================================
# Created by `bun x convex dev` or the Convex dashboard
CONVEX_DEPLOYMENT=dev:your-project-name
CONVEX_URL=https://your-project.convex.cloud
CONVEX_SITE_URL=https://your-project.convex.site
SITE_URL=http://localhost:5173

# ============================================
# AUTHENTICATION (Convex — @convex-dev/auth)
# ============================================
# Google OAuth for sign-in (Convex env: AUTH_GOOGLE_*)
# Create OAuth credentials at https://console.cloud.google.com
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# JWT signing (generate via Convex Auth / dashboard tooling)
# See https://docs.convex.dev/auth
JWKS={"keys":[]}
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# ============================================
# AI SERVICES (Convex)
# ============================================

# Together AI — LLMs, embeddings, TTS (https://api.together.xyz)
TOGETHER_AI_API_KEY=your-together-ai-key

TAVILY_API_KEY=your-tavily-key
MISTRAL_API_KEY=your-mistral-key
SUPADATA_API_KEY=your-supadata-key
ZEROENTROPY_API_KEY=your-zeroentropy-key
ZEROENTROPY_RERANK_MODEL=zerank-2

# Academic search (optional; higher rate limits with key)
SEMANTIC_SCHOLAR_API_KEY=
# PubMed contact email (optional; defaults in code if unset)
PUBMED_EMAIL=you@example.com

# ============================================
# LLM MODEL CONFIGURATION (Convex)
# ============================================
# Together-hosted models. "openai/" is the model family on Together, not the API provider.

FAST_LLM=openai/gpt-oss-20b
SMART_LLM=openai/gpt-oss-120b
REPORT_LLM=MiniMaxAI/MiniMax-M2.7
FLASHCARDS_LLM=MiniMaxAI/MiniMax-M2.7
QUIZ_LLM=MiniMaxAI/MiniMax-M2.7
MINDMAP_LLM=MiniMaxAI/MiniMax-M2.7
SPREADSHEET_LLM=MiniMaxAI/MiniMax-M2.7
WRITTEN_QUESTIONS_LLM=MiniMaxAI/MiniMax-M2.7
AUDIO_LLM=MiniMaxAI/MiniMax-M2.7

# ============================================
# AUDIO TTS (Convex — Kokoro voice IDs on Together)
# ============================================
AUDIO_VOICE_HOST_A=af_sky
AUDIO_VOICE_HOST_B=am_echo
# AUDIO_TTS_MODEL=hexgrad/Kokoro-82M

# ============================================
# BILLING & EMAIL (Convex)
# ============================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# STRIPE_PRO_YEARLY_PRICE_ID=price_...
# RESEND_API_KEY=re_...
# AUTH_RESEND_FROM=Solomind <noreply@yourdomain.com>

# ============================================
# RAG EVAL (dev deployment + local CLI)
# ============================================
# On Convex *dev* only (pushed via bootstrap or manually):
#   RAG_EVALS_ENABLED=true
#   RAG_EVAL_SECRET=<openssl rand -hex 16>
# Local CLI only (see evals/rag/env.eval.example — not pushed):
#   RAG_EVAL_CONVEX_URL=https://your-dev-deployment.convex.cloud
#   RAG_EVAL_SECRET=<same as Convex dev>
# Bootstrap: bun run eval:rag:bootstrap-env

# ============================================
# LOCAL-ONLY (not pushed to Convex)
# ============================================
# LangSmith tracing when running tools locally (not read in convex/)
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=solomindlm-development
# LANGCHAIN_TRACING_V2=true
#
# Agent map/reduce timeouts and chunk sizes live in convex/_agents/*/config.ts
# and studio job CONFIG — not environment variables.
