# ============================================
# SolomindLM Environment Variables
# ============================================
# Copy to .env (prod / Convex prod) and .env.local (dev / Convex dev).
# Pull from Convex:  bun run convex:env:pull
# Push to Convex:   bun run convex:env:push (dev) | convex:env:push:prod

# ============================================
# CONVEX (Required)
# ============================================
# These are created automatically when you run `bun x convex dev`
# Or get them from your Convex dashboard
CONVEX_DEPLOYMENT=dev:your-project-name
CONVEX_URL=https://your-project.convex.cloud
CONVEX_SITE_URL=https://your-project.convex.site
SITE_URL=http://localhost:5173

# ============================================
# AUTHENTICATION (Required)
# ============================================

# Better Auth Secret (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET=your-random-secret-here

# Google OAuth (get from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Auth crypto keys (generate with Better Auth CLI or manually)
# See: https://docs.convex.dev/auth
JWKS={"keys":[]}
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# ============================================
# AI SERVICES (Required for core functionality)
# ============================================

# Together AI (get from https://api.together.xyz)
# Primary AI provider for LLMs, embeddings, and TTS
TOGETHER_AI_API_KEY=your-together-ai-key

# Tavily Search (get from https://tavily.com)
TAVILY_API_KEY=your-tavily-key

# Mistral OCR (get from https://mistral.ai)
MISTRAL_API_KEY=your-mistral-key

# Supadata Extraction (get from https://supadata.ai)
SUPADATA_API_KEY=your-supadata-key

# ZeroEntropy Reranking (get from https://zeroentropy.dev)
ZEROENTROPY_API_KEY=your-zeroentropy-key
ZEROENTROPY_RERANK_MODEL=zerank-2

# SEMANTIC SCHOLAR
SEMANTIC_SCHOLAR_API_KEY="s2k-key"

# ============================================
# LLM MODEL CONFIGURATION (Optional)
# ============================================
# Customize which models are used for different features
# All models are hosted on Together AI (the "openai/" prefix is the model family name)
# Defaults shown below

FAST_LLM=openai/gpt-oss-20b
SMART_LLM=openai/gpt-oss-120b
REPORT_LLM=MiniMaxAI/MiniMax-M2.7
FLASHCARDS_LLM=MiniMaxAI/MiniMax-M2.7
QUIZ_LLM=MiniMaxAI/MiniMax-M2.7
MINDMAP_LLM=MiniMaxAI/MiniMax-M2.7
SLIDES_LLM=openai/gpt-oss-120b
SPREADSHEET_LLM=MiniMaxAI/MiniMax-M2.7
WRITTEN_QUESTIONS_LLM=MiniMaxAI/MiniMax-M2.7
AUDIO_LLM=MiniMaxAI/MiniMax-M2.7

# ============================================
# OPTIONAL SERVICES
# ============================================

# Stripe (for billing/subscriptions, get from https://stripe.com)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# STRIPE_PRO_YEARLY_PRICE_ID=price_...

# Resend Email (for OTP/password reset, get from https://resend.com)
# RESEND_API_KEY=re_...
# AUTH_RESEND_FROM=noreply@yourdomain.com

# ============================================
# AUDIO VOICES (Optional)
# ============================================
# Uncomment and set if you want custom TTS voices
# AUDIO_VOICE_HOST_1=https://...
# AUDIO_VOICE_HOST_2=https://...
# AUDIO_VOICE_HOST_3=https://...
# AUDIO_VOICE_HOST_4=https://...
