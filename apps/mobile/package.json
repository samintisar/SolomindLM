{
  "name": "@solomindlm/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "kill-port": "bun run ../web/scripts/kill-port.ts 8081",
    "dev": "bun run kill-port && bun x expo start --port 8081",
    "start": "bun run kill-port && bun x expo start --port 8081",
    "android": "bun run kill-port && bun x expo start --android --port 8081",
    "run:android": "node ./scripts/run-android.mjs",
    "run:android:device": "node ./scripts/run-android.mjs --device",
    "ios": "bun run kill-port && bun x expo start --ios --port 8081",
    "web": "bun run kill-port && bun x expo start --web --port 8081",
    "build:dev:ios": "bun x eas-cli build --profile development --platform ios",
    "build:dev:android": "bun x eas-cli build --profile development --platform android"
  },
  "dependencies": {
    "@convex-dev/auth": "0.0.90",
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "~7.11.0",
    "convex": "1.40.0",
    "expo": "~55.0.26",
    "expo-asset": "~55.0.17",
    "expo-audio": "~55.0.14",
    "expo-auth-session": "~55.0.4",
    "expo-build-properties": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.35",
    "expo-document-picker": "~55.0.13",
    "expo-font": "~55.0.8",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "~55.0.15",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-updates": "~55.0.24",
    "expo-web-browser": "~55.0.16",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "metro-resolver": "0.83.6",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
