{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@mobile/*": [
        "./src/*"
      ],
      "@convex/*": [
        "../../convex/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "src/types/env.d.ts",
    "expo-env.d.ts"
  ]
}
