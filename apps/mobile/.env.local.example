# Mobile dev env — copy to .env.local
# EXPO_PUBLIC_CONVEX_URL must match VITE_CONVEX_URL in apps/web/.env.local (auth sync)
#
# After clone or pulling mobile/Android changes, run `bun install` from repo root.
# Root bunfig.toml uses hoisted node_modules (required for Android CMake on Windows).

EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Web app loaded inside the WebView shell (Vite dev server — run `bun run dev:web` from repo root)
#
# Physical Android device (USB or Wi‑Fi): PC LAN IP + port 5173 (same Wi‑Fi as phone)
#   ipconfig → IPv4, e.g. http://192.168.68.110:5173
EXPO_PUBLIC_WEB_URL=http://192.168.68.110:5173
#
# Android emulator only (special alias to host machine):
# EXPO_PUBLIC_WEB_URL=http://10.0.2.2:5173
# Also set Convex dev SITE_URL so OAuth redirects work (comma-separated):
#   Emulator:  npx convex env set SITE_URL "http://localhost:5173,http://10.0.2.2:5173"
#   LAN phone: npx convex env set SITE_URL "http://localhost:5173,http://192.168.68.110:5173"
# Native OAuth uses the solomindlm:// app scheme (makeRedirectUri) — allowed in convex/auth.ts.
#
# USB device with adb reverse (optional — then localhost works on the phone):
#   adb reverse tcp:5173 tcp:5173
#   adb reverse tcp:8081 tcp:8081
# EXPO_PUBLIC_WEB_URL=http://127.0.0.1:5173

# Sentry — Project Settings → Client Keys (DSN). Enables @sentry/react-native in the app.
EXPO_PUBLIC_SENTRY_DSN=https://your-key@o0000000000000000.ingest.us.sentry.io/0000000000000000

# Sentry — Organization Settings → Developer Settings → Auth Tokens (project:releases, org:read).
# Build-time only: uploads source maps on native release / EAS builds. Do not commit a real token.
# app.json plugin uses organization "solomindlm" and project "react-native".
# For EAS: `eas env:create --name SENTRY_AUTH_TOKEN --value "sntrys_..." --environment production --visibility secret`
# SENTRY_AUTH_TOKEN=

# Optional: push notifications (EAS project UUID from expo.dev)
# EXPO_PUBLIC_EAS_PROJECT_ID=
