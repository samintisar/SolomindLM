# Backend API URL
# Development: http://localhost:3001
# Production: https://solomindlmapi-production.up.railway.app
VITE_API_URL=http://localhost:3001

# Stripe publishable key for payments
# Get keys from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Supabase configuration for OAuth (frontend client)
# Get these from your Supabase project settings
# For OAuth flow, the frontend initiates the request to set state cookies properly
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
