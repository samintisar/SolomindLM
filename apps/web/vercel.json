{
  "buildCommand": "cd ../.. && bun x convex deploy --typecheck disable --cmd \"bun run build:prod\" --cmd-url-env-var-name VITE_CONVEX_URL",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "cd ../.. && bun install && cd apps/web && bun install",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://tame-gecko-736.convex.site/api/:path*" },
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
