{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && if [ \"$VERCEL_ENV\" = \"preview\" ]; then bun run build:prod; else bun x convex deploy --cmd \"bun run build:prod\" --cmd-url-env-var-name VITE_CONVEX_URL; fi",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "cd ../.. && bun install --frozen-lockfile",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "solomindlm.com" }],
      "destination": "https://www.solomindlm.com/:path*",
      "permanent": true
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/api/(.*)",
      "dest": "${VITE_CONVEX_SITE_URL}/api/$1",
      "env": ["VITE_CONVEX_SITE_URL"]
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
