{
  "buildCommand": "cd ../.. && bunx convex codegen && cd apps/web && bun run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "cd ../.. && bun install && cd apps/web && bun install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://tame-gecko-736.convex.site/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
