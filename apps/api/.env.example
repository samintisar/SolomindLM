# ============================================================
# SERVER
# ============================================================
PORT=3001
NODE_ENV=development

# ============================================================
# SUPABASE
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# POSTGRESQL (Graphile Worker)
# ============================================================
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# ============================================================
# GRAPHILE WORKER CONFIGURATION
# ============================================================
# Number of jobs to process concurrently per worker instance
WORKER_CONCURRENCY=5
# Number of worker instances (for horizontal scaling calculation)
WORKER_INSTANCES=1
# Maximum database pool size (auto-calculated: WORKER_INSTANCES * WORKER_CONCURRENCY + 5)
DB_POOL_MAX=10

# ============================================================
# AI SERVICES
# ============================================================
COHERE_API_KEY=your-cohere-api-key
COHERE_EMBEDDING_MODEL=embed-multilingual-v3.0
COHERE_RERANK_MODEL=rerank-v4.0-fast
MISTRAL_API_KEY=your-mistral-api-key
TOGETHER_AI_API_KEY=your-together-ai-api-key
DEEPGRAM_API_KEY=your-deepgram-api-key
SUPADATA_API_KEY=your-supadata-api-key
TAVILY_API_KEY=your-tavily-api-key

# ============================================================
# LLM MODELS
# ============================================================
FAST_LLM=meta-llama/Llama-3.2-3B-Instruct-Turbo
SMART_LLM=Qwen/Qwen3-Next-80B-A3B-Instruct

# ============================================================
# Vector embeddings
# ============================================================
COHERE_EMBEDDING_MODEL=embed-multilingual-v3.0
COHERE_RERANK_MODEL=rerank-v4.0-fast

# ============================================================
# Audio
# ============================================================
AUDIO_VOICE_HOST_A=aura-2-thalia-en
AUDIO_VOICE_HOST_B=aura-2-hermes-en

# ============================================================
# FLASHCARD GENERATION
# ============================================================
FLASHCARD_MAP_CHUNK_SIZE=30000                           # Map phase: 30K chars ≈ 7.5K tokens (~6% of 131K context)
FLASHCARD_MAP_TIMEOUT_MS=180000                          # Map phase timeout: 3 minutes
FLASHCARD_REDUCE_CHUNK_SIZE=60000                        # Reduce phase: 60K chars ≈ 15K tokens (~6% of 261K context)
FLASHCARD_REDUCE_TIMEOUT_MS=240000                       # Reduce phase timeout: 4 minutes
FLASHCARD_MIN_CARDS_PER_CHUNK=2                          # Minimum cards per chunk
FLASHCARD_MAX_CARDS_PER_CHUNK=18                         # Maximum cards per chunk
FLASHCARD_MIN_CHUNKS=3                                   # Minimum chunks to process

# ============================================================
# MIND MAP GENERATION
# ============================================================
MINDMAP_MAP_CHUNK_SIZE=15000                             # Map phase: 15K chars ≈ 3.75K tokens (~3% of 131K context)
MINDMAP_REDUCE_CHUNK_SIZE=30000                          # Reduce phase: 30K chars for aggregation

# ============================================================
# REPORT GENERATION
# ============================================================
REPORT_MAP_CHUNK_SIZE=30000                              # Map phase: 30K chars ≈ 7.5K tokens (~6% of 131K context)
REPORT_MAP_MAX_OUTPUT_TOKENS=8192                        # Max OUTPUT tokens for map phase (extracting topics/insights)
REPORT_REDUCE_CHUNK_SIZE=60000                           # Reduce phase: 60K chars ≈ 15K tokens (~6% of 261K context)
REPORT_REDUCE_MAX_OUTPUT_TOKENS=32000                    # Max OUTPUT tokens for reduce phase (final report generation)
REPORT_MAX_TOKENS=64000                                  # Max tokens for internal processing (collapse phase)

# ============================================================
# QUIZ GENERATION
# ============================================================
QUIZ_MAP_CHUNK_SIZE=20000                               # Map phase: 20K chars ≈ 5K tokens (~4% of 131K context)
QUIZ_MAP_TIMEOUT_MS=180000                              # Map phase timeout: 3 minutes
QUIZ_REDUCE_CHUNK_SIZE=40000                            # Reduce phase: 40K chars ≈ 10K tokens (~4% of 261K context)
QUIZ_REDUCE_TIMEOUT_MS=240000                           # Reduce phase timeout: 4 minutes

# ============================================================
# WRITTEN QUESTIONS GENERATION
# ============================================================
WRITTEN_QUESTIONS_MAP_CHUNK_SIZE=30000                  # Map phase: 30K chars ≈ 7.5K tokens (~6% of 131K context)
WRITTEN_QUESTIONS_MAP_TIMEOUT_MS=180000                 # Map phase timeout: 3 minutes
WRITTEN_QUESTIONS_REDUCE_CHUNK_SIZE=60000               # Reduce phase: 60K chars ≈ 15K tokens (~6% of 261K context)
WRITTEN_QUESTIONS_REDUCE_TIMEOUT_MS=240000              # Reduce phase timeout: 4 minutes

# ============================================================
# AUDIO OVERVIEW GENERATION
# ============================================================
AUDIO_MAP_CHUNK_SIZE=15000                               # Map phase: 15K chars for beat extraction
AUDIO_MAP_TIMEOUT_MS=180000                              # Map phase timeout: 3 minutes
AUDIO_REDUCE_CHUNK_SIZE=40000                            # Reduce phase: 40K chars for dialogue synthesis
AUDIO_REDUCE_TIMEOUT_MS=300000                           # Reduce phase timeout: 5 minutes
AUDIO_TTS_TIMEOUT_MS=300000                              # TTS timeout for Deepgram: 5 minutes
AUDIO_VOICE_HOST_A=aura-2-thalia-en                      # Deepgram voice model for host A
AUDIO_VOICE_HOST_B=aura-2-hermes-en                      # Deepgram voice model for host B

# ============================================================
# CHAT/RAG CONFIGURATION
# ============================================================
CHAT_LLM_TEMPERATURE=0.7                                # Lower = more focused, Higher = more creative
CHAT_MAX_HISTORY_MESSAGES=20                            # How many past messages to include in context
CHAT_VECTOR_MATCH_THRESHOLD=0.5                         # Similarity threshold (0-1), lower = more matches
CHAT_VECTOR_MATCH_COUNT=10                              # Results per query variant
CHAT_RERANK_THRESHOLD=3                                 # Min results before using Cohere reranking
CHAT_MAX_RESULTS=20                                     # Max results to return
CHAT_QUERY_VARIANTS_MAX=5                               # Max query variants to generate
CHAT_DOCUMENT_MAX_CHARS=3000                            # Max chars in document summaries

# ============================================================
# CORS
# ============================================================
CORS_ORIGIN=http://localhost:5173
