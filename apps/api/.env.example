# Server
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PostgreSQL connection for Graphile Worker
# Use your Supabase connection string with ?pgbouncer=true
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# AI Services
COHERE_API_KEY=your-cohere-api-key
MISTRAL_API_KEY=your-mistral-api-key
TOGETHER_AI_API_KEY=your-together-ai-api-key
SUPADATA_API_KEY=your-supadata-api-key
TAVILY_API_KEY=your-tavily-api-key

# LLM Models
FAST_LLM=meta-llama/Llama-3.2-3B-Instruct-Turbo
SMART_LLM=Qwen/Qwen3-Next-80B-A3B-Instruct

# Flashcard Generation
# Map phase (fast_llm): 30K chars ≈ 7.5K tokens (~6% of 131K context)
FLASHCARD_MAP_CHUNK_SIZE=30000
# Reduce phase (smart_llm): 60K chars ≈ 15K tokens (~6% of 261K context)
FLASHCARD_REDUCE_CHUNK_SIZE=60000
# Cards per chunk bounds
FLASHCARD_MIN_CARDS_PER_CHUNK=2
FLASHCARD_MAX_CARDS_PER_CHUNK=18
# Minimum chunks to process
FLASHCARD_MIN_CHUNKS=3

# Mind Map Generation
# Map phase: 15K chars ≈ 3.75K tokens (~3% of 131K context)
MINDMAP_MAP_CHUNK_SIZE=15000
# Reduce phase: 30K chars for aggregation
MINDMAP_REDUCE_CHUNK_SIZE=30000

# Report Generation
# Map phase: 30K chars ≈ 7.5K tokens (~6% of 131K context)
REPORT_MAP_CHUNK_SIZE=30000
# Reduce phase: 60K chars ≈ 15K tokens (~6% of 261K context)
REPORT_REDUCE_CHUNK_SIZE=60000

# Quiz Generation
# Map phase: 20K chars ≈ 5K tokens (~4% of 131K context)
QUIZ_MAP_CHUNK_SIZE=20000
# Reduce phase: 40K chars ≈ 10K tokens (~4% of 261K context)
QUIZ_REDUCE_CHUNK_SIZE=40000

# CORS
CORS_ORIGIN=http://localhost:5173
