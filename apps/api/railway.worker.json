{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun install && cd apps/api && bun run build:worker",
    "watchPatterns": ["apps/api/**"]
  },
  "deploy": {
    "startCommand": "bun apps/api/dist/worker.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "numReplicas": 2
  },
  "rootDirectory": "."
}
