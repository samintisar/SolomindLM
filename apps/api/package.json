{
  "name": "@solomindlm/api",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --clean --outDir dist --minify",
    "build:worker": "tsup src/utils/worker.ts --format esm --clean --outDir dist --minify",
    "type-check": "tsc --noEmit",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "worker": "tsx src/utils/worker.ts",
    "clear-jobs": "tsx src/utils/clearJobs.ts"
  },
  "dependencies": {
    "@langchain/community": "^1.1.1",
    "@langchain/core": "^1.1.8",
    "@langchain/langgraph": "^1.0.7",
    "@langchain/openai": "^0.4.0",
    "@langchain/textsplitters": "^1.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "@supadata/js": "^1.0.0",
    "axios": "^1.6.5",
    "cookie": "^1.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.0.1",
    "graphile-worker": "^0.16.6",
    "helmet": "^8.0.0",
    "langchain": "^1.0.0",
    "langsmith": "^0.4.7",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.83.0",
    "p-limit": "^7.2.0",
    "pg": "^8.11.3",
    "stripe": "^20.1.2",
    "tiktoken": "^1.0.22",
    "zeroentropy": "^0.1.0-alpha.7",
    "zhipuai-sdk-nodejs-v4": "^0.1.12",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/pg": "^8.16.0",
    "nodemon": "^3.0.2",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
