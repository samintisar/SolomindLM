{
  "name": "solomindlm-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.2.2",
  "workspaces": {
    "packages": [
      "apps/web",
      "apps/mobile"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.2.2"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "scripts": {
    "dev": "bun run --elide-lines=0 --filter \"./apps/**\" dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:mobile": "bun run --cwd apps/mobile dev",
    "build": "bun run --filter \"./apps/**\" build",
    "build:prod": "bun run --filter @solomindlm/web build",
    "typecheck:convex": "bun x tsgo --noEmit -p convex/tsconfig.json",
    "typecheck:web": "bun x tsgo --noEmit -p apps/web/tsconfig.json",
    "typecheck:mobile": "bun x tsgo --noEmit -p apps/mobile/tsconfig.json",
    "convex:env:push": "node scripts/push-convex-env.js",
    "convex:env:push:prod": "node scripts/push-convex-env.js --prod",
    "convex:env:push:dry": "node scripts/push-convex-env.js --dry-run",
    "link:claude-skills": "node scripts/link-claude-skills.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun run test:web && bun run test:convex",
    "test:watch": "bun run --cwd apps/web test:watch",
    "test:web": "bun run --cwd apps/web test",
    "test:web:watch": "bun run --cwd apps/web test:watch",
    "test:web:coverage": "bun run --cwd apps/web test:coverage",
    "test:convex": "vitest run --config vitest.convex.config.ts",
    "test:convex:watch": "vitest --config vitest.convex.config.ts",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "eval:rag": "bun run evals/rag/cli.ts",
    "eval:rag:dry": "bun run evals/rag/cli.ts --dry-run",
    "eval:studio": "bun run evals/rag/cli.ts --runner report,flashcards,quiz,mindmap,infographic,spreadsheet,writtenQuestions,audioScript",
    "eval:studio:dry": "bun run evals/rag/cli.ts --dry-run --runner report,flashcards,quiz,mindmap,infographic,spreadsheet,writtenQuestions,audioScript",
    "eval:rag:bootstrap-env": "node scripts/bootstrap-rag-eval-env.js",
    "eval:ragas": "conda run -n solomindlm-rag-evals python evals/ragas/run_ragas.py",
    "e2e:convex:cleanup": "node scripts/cleanup-e2e.mjs",
    "e2e:convex:cleanup-folders": "node scripts/cleanup-e2e-folders.mjs",
    "e2e:convex:cleanup-notebooks": "node scripts/cleanup-e2e-notebooks.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260503.1",
    "convex": "1.36.0",
    "convex-test": "^0.0.50",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@auth/core": "0.37.2",
    "@breezystack/lamejs": "^1.2.7",
    "@convex-dev/action-cache": "^0.3.0",
    "@convex-dev/auth": "0.0.90",
    "@convex-dev/persistent-text-streaming": "^0.3.2",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/stripe": "^0.1.4",
    "@convex-dev/workpool": "^0.3.2",
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.44",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/openai": "^1.4.5",
    "@langchain/textsplitters": "^1.0.1",
    "@oslojs/crypto": "^1.0.1",
    "@standard-schema/spec": "^1.1.0",
    "@supadata/js": "^1.4.0",
    "@tavily/core": "^0.7.3",
    "convex-helpers": "^0.1.115",
    "langsmith": "^0.4.12",
    "p-limit": "^7.3.0",
    "resend": "^4.8.0",
    "stripe": "^20.4.1",
    "together-ai": "^0.39.0",
    "zeroentropy": "^0.1.0-alpha.10",
    "zod": "^4.4.2"
  }
}
