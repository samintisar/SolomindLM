{
  "name": "solomindlm-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.2.2",
  "workspaces": {
    "packages": ["apps/web"]
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.2.2"
  },
  "scripts": {
    "dev": "bun run --elide-lines=0 --filter \"./apps/**\" dev",
    "dev:web": "bun run --elide-lines=0 --filter @solomindlm/web dev",
    "build": "bun run --filter \"./apps/**\" build",
    "build:prod": "bun run --filter @solomindlm/web build",
    "typecheck:convex": "bun x tsgo --noEmit -p convex/tsconfig.json",
    "typecheck:web": "bun x tsgo --noEmit -p apps/web/tsconfig.json",
    "convex:env:push": "node scripts/push-convex-env.js",
    "convex:env:push:prod": "node scripts/push-convex-env.js --prod",
    "convex:env:push:dry": "node scripts/push-convex-env.js --dry-run"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.0.10",
    "@typescript/native-preview": "^7.0.0-dev.20260130.1",
    "convex": "^1.34.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@auth/core": "0.37.2",
    "@convex-dev/action-cache": "^0.3.0",
    "@convex-dev/auth": "0.0.90",
    "@convex-dev/persistent-text-streaming": "^0.3.0",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/stripe": "^0.1.3",
    "@convex-dev/workpool": "^0.3.1",
    "@langchain/community": "^1.1.8",
    "@langchain/core": "^1.1.17",
    "@langchain/langgraph": "^1.1.2",
    "@langchain/openai": "^1.2.3",
    "@langchain/textsplitters": "^1.0.1",
    "@standard-schema/spec": "^1.1.0",
    "@supadata/js": "^1.3.2",
    "convex-helpers": "^0.1.111",
    "dompurify": "^3.3.1",
    "langsmith": "^0.4.10",
    "openai": "^6.33.0",
    "p-limit": "^7.2.0",
    "stripe": "^20.0.0",
    "zeroentropy": "^0.1.0-alpha.7",
    "zod": "^3.23.8"
  }
}
