# RAG Evaluation Environment Variables
#
# Copy this file to the repo root as `.env` (or merge into your existing `.env`):
#   cp evals/rag/env.eval.example .env
#
# The eval CLI (bun run eval:rag) reads these from the repo-root `.env` via Bun's
# automatic dotenv loading.
#
# Convex dev must also have (pushed separately, e.g. eval:rag:bootstrap-env):
#   RAG_EVALS_ENABLED=true
#   RAG_EVAL_SECRET=<same value as below>
#
# RAG_EVAL_CONVEX_URL is local-only and is NOT pushed to Convex.

# ─── Required ────────────────────────────────────────────────────────────────

# Your *dev* Convex deployment URL (https://<slug>.convex.cloud).
# Do NOT point this at prod evals write data and run expensive agents.
RAG_EVAL_CONVEX_URL=https://your-dev-deployment.convex.cloud

# Shared secret between the eval CLI and the Convex deployment.
# Must be >= 16 characters and match the RAG_EVAL_SECRET set on the deployment.
# Generate one:  openssl rand -hex 16
RAG_EVAL_SECRET=replace-with-a-random-secret-min-16-chars

# ─── Optional: LLM Judge ─────────────────────────────────────────────────────

# Together AI API key for LLM-as-a-judge metrics (correctness, faithfulness,
# completeness). Required if you want semantic evaluation beyond deterministic
# string matching. Also used by embedding services in the eval actions.
TOGETHER_AI_API_KEY=your-together-ai-key
